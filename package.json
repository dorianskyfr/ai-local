{
  "name": "ai-local",
  "productName": "AI Local",
  "version": "1.5.0",
  "description": "Application de chat avec un modèle d'IA local qui s'entraîne tout seul (texte, images, vidéos)",
  "main": "main.js",
  "author": "dorianskyfr",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "fr.dorianskyfr.ailocal",
    "productName": "AI Local",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "llm-main.js",
      "renderer/**/*",
      "package.json",
      "!**/node_modules/@node-llama-cpp/*cuda*/**",
      "!**/node_modules/@node-llama-cpp/*vulkan*/**"
    ],
    "asarUnpack": [
      "**/node_modules/node-llama-cpp/**",
      "**/node_modules/@node-llama-cpp/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "AI-Local-${version}-portable.exe"
    }
  },
  "dependencies": {
    "node-llama-cpp": "^3.19.0"
  }
}
